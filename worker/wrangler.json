{
	"name": "hmc-worker",
	"main": "src/index.js",
	"compatibility_date": "2026-02-26",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "ORDERS",
			"id": "",
			"preview_id": ""
		}
	],
	"routes": [
		{
			"pattern": "hmc-cycling.org/checkout*",
			"zone_name": "hmc-cycling.org"
		},
		{
			"pattern": "hmc-cycling.org/webhook*",
			"zone_name": "hmc-cycling.org"
		}
	]
}
