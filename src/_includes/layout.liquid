<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | HMC-Cycling.org</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/styles.css">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-brand">HMC-Cycling.org</a>
      <div class="nav-links">
        <a href="/">Shop</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <button class="cart-icon-btn" id="cart-open" aria-label="Open cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="cart-badge" id="cart-badge" hidden>0</span>
        </button>
      </div>
    </div>
  </nav>

  <div class="cart-overlay" id="cart-overlay" hidden>
    <div class="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart">
      <div class="cart-header">
        <h2>Cart</h2>
        <div class="cart-header-actions">
          <button class="cart-clear-btn" id="cart-clear" hidden>Clear all</button>
          <button class="cart-close" id="cart-close" aria-label="Close cart">&#215;</button>
        </div>
      </div>
      <div class="cart-empty" id="cart-empty"><p>Your cart is empty.</p></div>
      <div class="cart-items" id="cart-items"></div>
      <div class="cart-footer" id="cart-footer" hidden>
        <div class="cart-total-row">
          <span>Total</span>
          <span id="cart-total">$0.00</span>
        </div>
        <p class="cart-shipping-note">Shipping calculated at checkout</p>
        {% if site.preview %}
          <p class="preview-message">Coming soon — we'd love your feedback!</p>
          <button class="buy-button cart-checkout-btn" id="cart-checkout" disabled>Checkout</button>
        {% else %}
          <button class="buy-button cart-checkout-btn" id="cart-checkout">Checkout</button>
        {% endif %}
      </div>
    </div>
  </div>

  <main>
    {{ content }}
  </main>
  <footer>
    <p>© HMC-Cycling.org</p>
  </footer>

  <script>
    // Valid (slug:color:size) combinations for the current catalog.
    // Used to purge stale cart items when products change.
    const _HMC_CATALOG = new Set([{% for product in products %}{% for color in product.colors %}{% for s in color.sizes %}"{{ product.slug }}:{{ color.name }}:{{ s.size }}",{% endfor %}{% endfor %}{% endfor %}]);

    const Cart = {
      KEY: 'hmc_cart',
      get() {
        try { return JSON.parse(localStorage.getItem(this.KEY)) || []; }
        catch { return []; }
      },
      save(items) {
        localStorage.setItem(this.KEY, JSON.stringify(items));
        this.refresh();
      },
      add(slug, name, color, size, price, image) {
        const items = this.get();
        const existing = items.find(i => i.slug === slug && i.color === color && i.size === size);
        if (existing) existing.qty += 1;
        else items.push({ slug, name, color, size, price, image, qty: 1 });
        this.save(items);
        this.open();
      },
      remove(slug, color, size) {
        this.save(this.get().filter(i => !(i.slug === slug && i.color === color && i.size === size)));
      },
      changeQty(slug, color, size, delta) {
        const items = this.get();
        const item = items.find(i => i.slug === slug && i.color === color && i.size === size);
        if (!item) return;
        item.qty += delta;
        if (item.qty <= 0) this.save(items.filter(i => !(i.slug === slug && i.color === color && i.size === size)));
        else this.save(items);
      },
      clear() { this.save([]); },
      purgeUnknown() {
        if (_HMC_CATALOG.size === 0) return;
        try {
          const raw = JSON.parse(localStorage.getItem(this.KEY) || '[]');
          const valid = raw.filter(i => _HMC_CATALOG.has(`${i.slug}:${i.color}:${i.size}`));
          if (valid.length !== raw.length) localStorage.setItem(this.KEY, JSON.stringify(valid));
        } catch {}
      },
      count() { return this.get().reduce((s, i) => s + i.qty, 0); },
      total() { return this.get().reduce((s, i) => s + i.price * i.qty, 0); },
      open() {
        document.getElementById('cart-overlay').removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
        this.render();
      },
      close() {
        document.getElementById('cart-overlay').setAttribute('hidden', '');
        document.body.style.overflow = '';
      },
      refresh() {
        const badge = document.getElementById('cart-badge');
        if (!badge) return;
        const count = this.count();
        badge.textContent = count;
        count > 0 ? badge.removeAttribute('hidden') : badge.setAttribute('hidden', '');
        this.render();
      },
      render() {
        const items = this.get();
        const el = document.getElementById('cart-items');
        const footer = document.getElementById('cart-footer');
        const empty = document.getElementById('cart-empty');
        if (!el) return;
        const clearBtn = document.getElementById('cart-clear');
        if (items.length === 0) {
          el.innerHTML = '';
          footer.setAttribute('hidden', '');
          empty.removeAttribute('hidden');
          if (clearBtn) clearBtn.setAttribute('hidden', '');
          return;
        }
        empty.setAttribute('hidden', '');
        footer.removeAttribute('hidden');
        if (clearBtn) clearBtn.removeAttribute('hidden');
        el.innerHTML = items.map(item => `
          <div class="cart-item">
            <img class="cart-item-img" src="${item.image}" alt="${item.name}">
            <div class="cart-item-info">
              <div class="cart-item-name">${item.name}</div>
              <div class="cart-item-meta">${item.color} &nbsp;·&nbsp; ${item.size} &nbsp;·&nbsp; $${(item.price * item.qty).toFixed(2)}</div>
            </div>
            <div class="cart-item-controls">
              <button class="cart-qty-btn" data-slug="${item.slug}" data-color="${item.color}" data-size="${item.size}" data-delta="-1">−</button>
              <span class="cart-qty">${item.qty}</span>
              <button class="cart-qty-btn" data-slug="${item.slug}" data-color="${item.color}" data-size="${item.size}" data-delta="1">+</button>
              <button class="cart-remove" data-slug="${item.slug}" data-color="${item.color}" data-size="${item.size}" aria-label="Remove">&#215;</button>
            </div>
          </div>
        `).join('');
        document.getElementById('cart-total').textContent = '$' + this.total().toFixed(2);
        el.querySelectorAll('.cart-qty-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            this.changeQty(btn.dataset.slug, btn.dataset.color, btn.dataset.size, parseInt(btn.dataset.delta));
          });
        });
        el.querySelectorAll('.cart-remove').forEach(btn => {
          btn.addEventListener('click', () => this.remove(btn.dataset.slug, btn.dataset.color, btn.dataset.size));
        });
      },
      async checkout() {
        const items = this.get();
        if (!items.length) return;
        const btn = document.getElementById('cart-checkout');
        btn.textContent = 'Processing\u2026';
        btn.disabled = true;
        try {
          const res = await fetch('/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: items.map(i => ({ slug: i.slug, color: i.color, size: i.size, qty: i.qty })) }),
          });
          const data = await res.json();
          if (data.url) window.location.href = data.url;
          else throw new Error('no url');
        } catch {
          btn.textContent = 'Checkout';
          btn.disabled = false;
          alert('Something went wrong. Please try again.');
        }
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      Cart.purgeUnknown();
      Cart.refresh();
      document.getElementById('cart-open').addEventListener('click', () => Cart.open());
      document.getElementById('cart-close').addEventListener('click', () => Cart.close());
      document.getElementById('cart-clear').addEventListener('click', () => Cart.clear());
      document.getElementById('cart-overlay').addEventListener('click', e => {
        if (e.target === document.getElementById('cart-overlay')) Cart.close();
      });
      const checkoutBtn = document.getElementById('cart-checkout');
      if (checkoutBtn) checkoutBtn.addEventListener('click', () => Cart.checkout());
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && !document.getElementById('cart-overlay').hasAttribute('hidden')) Cart.close();
      });
    });
  </script>
</body>
</html>
