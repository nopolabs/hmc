---
title: Home
layout: layout.njk
---

<div class="hero">
  <h1>HMC, <em>Cycling.</em></h1>
</div>

<div class="products">
  {% for product in products %}
    <div class="product-card">
      <div class="product-image-wrapper">
        <img class="product-main-image" src="{{ product.images[0] }}" alt="{{ product.name }}">
      </div>
      {% if product.images.length > 1 %}
        <div class="product-thumbnails">
          {% for img in product.images %}
            <img src="{{ img }}" alt="{{ product.name }}" onclick="this.closest('.product-card').querySelector('.product-main-image').src = this.src">
          {% endfor %}
        </div>
      {% endif %}
      <div class="product-title-price">
        <h2>{{ product.name }}</h2>
        <p>${{ product.variants[0].price }}</p>
      </div>
      {% if product.description %}
        <p class="product-description">{{ product.description }}</p>
      {% endif %}
      <form action="/checkout" method="GET">
        <input type="hidden" name="slug" value="{{ product.slug }}">
        <div>
          Size:
          <select name="size" required>
            <option value="" selected disabled>Select</option>
            {% for variant in product.variants %}
              <option value="{{ variant.size }}">{{ variant.size }}</option>
            {% endfor %}
          </select>
        </div>
        {% if site.preview %}
          <p class="preview-message">Coming soon — we'd love your feedback!</p>
        {% else %}
          <button type="submit" class="buy-button">Buy Now</button>
        {% endif %}
      </form>
    </div>
  {% endfor %}
</div>
