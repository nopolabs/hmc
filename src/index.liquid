---
title: Home
layout: layout.liquid
---

<div class="hero">
  <h1>HMC, <em>Cycling.</em></h1>
</div>

{% comment %} Transparent 1x1 placeholder: the real (randomly-chosen) color image is
   set by JS on load, so the page never fetches the white default first. {% endcomment %}
{% assign blankImage = "data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" %}
<div class="products">
  {% for product in products %}
    {% assign pmTable = product.size_guide.product_measure %}
    {% assign myTable = product.size_guide.measure_yourself %}

    <div class="product-card">
      <div class="product-image-wrapper">
        <img class="product-main-image" src="{{ blankImage }}" alt="{{ product.name }}">
      </div>

      {% if product.colors[0].images.back %}
        <div class="product-thumbnails">
          <img class="thumb thumb-front"
               src="{{ blankImage }}"
               loading="lazy"
               alt="{{ product.name }} front"
               onclick="this.closest('.product-card').querySelector('.product-main-image').src=this.src">
          <img class="thumb thumb-back"
               src="{{ blankImage }}"
               loading="lazy"
               alt="{{ product.name }} back"
               onclick="this.closest('.product-card').querySelector('.product-main-image').src=this.src">
        </div>
      {% endif %}

      <div class="product-title-price">
        <h2>{{ product.name }}</h2>
        <p>${{ product.price }}</p>
      </div>

      {% if product.description %}
        <p class="product-description">{{ product.description }}</p>
      {% endif %}

      {% if product.size_guide %}
        <button class="sg-trigger" data-size-guide="{{ product.slug }}" type="button">Size guide</button>
      {% endif %}

      <div class="product-actions"
           data-slug="{{ product.slug }}"
           data-name="{{ product.name }}"
           data-price="{{ product.price }}"
           data-colors="{{ product.colors | json | escape }}">

        <div class="variant-row">
          <span class="variant-label">Color</span>
          <div class="color-swatches">
            {% for color in product.colors %}
              <button type="button"
                      class="color-swatch"
                      data-color="{{ color.name }}"
                      style="background-color: {{ color.hex }};"
                      aria-label="{{ color.name }}"></button>
            {% endfor %}
          </div>
        </div>

        <div class="variant-row">
          <span class="variant-label">Size</span>
          <select class="size-select">
            <option value="" selected disabled>—</option>
          </select>
        </div>

        <button type="button" class="buy-button add-to-cart-btn" disabled>Add to Cart</button>
      </div>
    </div>

    {% if product.size_guide %}
    <div class="sg-overlay" id="sg-{{ product.slug }}" hidden>
      <div class="sg-modal" role="dialog" aria-modal="true" aria-labelledby="sg-title-{{ product.slug }}">
        <div class="sg-header">
          <h2 id="sg-title-{{ product.slug }}">Size guide</h2>
          <button class="sg-close" aria-label="Close">&#215;</button>
        </div>
        <div class="sg-tabs">
          {% if pmTable %}<button class="sg-tab active" data-tab="pm" type="button">Product measurements</button>{% endif %}
          {% if myTable %}<button class="sg-tab{% unless pmTable %} active{% endunless %}" data-tab="my" type="button">Measure yourself</button>{% endif %}
        </div>

        {% if pmTable %}
        <div class="sg-panel" data-panel="pm">
          <div class="sg-diagram">
            <img src="{{ pmTable.image_url }}" alt="Product measurement diagram">
            <div class="sg-diagram-desc">{{ pmTable.image_description }}</div>
          </div>
          <table class="sg-table">
            <thead>
              <tr>
                <th>Size</th>
                {% for m in pmTable.measurements %}<th>{{ m.type_label }}</th>{% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in pmTable.measurements[0].values %}
                {% assign rowIndex = forloop.index0 %}
                <tr>
                  <td>{{ row.size }}</td>
                  {% for m in pmTable.measurements %}
                    {% assign v = m.values[rowIndex] %}
                    <td>{% if v.value %}{{ v.value }}{% else %}{{ v.min_value }}–{{ v.max_value }}{% endif %}</td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
          <p class="sg-note">All measurements in inches. May vary by up to 2&#8243; (5&nbsp;cm).</p>
        </div>
        {% endif %}

        {% if myTable %}
        <div class="sg-panel" data-panel="my"{% if pmTable %} hidden{% endif %}>
          <div class="sg-diagram">
            <img src="{{ myTable.image_url }}" alt="Measure yourself diagram">
            <div class="sg-diagram-desc">{{ myTable.image_description }}</div>
          </div>
          <table class="sg-table">
            <thead>
              <tr>
                <th>Size</th>
                {% for m in myTable.measurements %}<th>{{ m.type_label }}</th>{% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in myTable.measurements[0].values %}
                {% assign rowIndex = forloop.index0 %}
                <tr>
                  <td>{{ row.size }}</td>
                  {% for m in myTable.measurements %}
                    {% assign v = m.values[rowIndex] %}
                    <td>{% if v.value %}{{ v.value }}{% else %}{{ v.min_value }}–{{ v.max_value }}{% endif %}</td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
          <p class="sg-note">All measurements in inches. May vary by up to 2&#8243; (5&nbsp;cm).</p>
        </div>
        {% endif %}

      </div>
    </div>
    {% endif %}
  {% endfor %}
</div>

<script>
  // ── Size guide ──────────────────────────────────────────────────────────────
  document.querySelectorAll('[data-size-guide]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('sg-' + btn.dataset.sizeGuide).removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeSg(overlay) {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.sg-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => { if (e.target === overlay) closeSg(overlay); });
    overlay.querySelector('.sg-close').addEventListener('click', () => closeSg(overlay));
  });

  document.querySelectorAll('.sg-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const modal = tab.closest('.sg-modal');
      modal.querySelectorAll('.sg-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      modal.querySelectorAll('.sg-panel').forEach(p => p.hidden = true);
      modal.querySelector('[data-panel="' + tab.dataset.tab + '"]').hidden = false;
    });
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape')
      document.querySelectorAll('.sg-overlay:not([hidden])').forEach(closeSg);
  });

  // ── Product cards ───────────────────────────────────────────────────────────
  document.querySelectorAll('.product-actions').forEach(actions => {
    const card       = actions.closest('.product-card');
    const colors     = JSON.parse(actions.dataset.colors);
    const mainImg    = card.querySelector('.product-main-image');
    const thumbFront = card.querySelector('.thumb-front');
    const thumbBack  = card.querySelector('.thumb-back');
    const sizeSelect = actions.querySelector('.size-select');
    const addBtn     = actions.querySelector('.add-to-cart-btn');

    let selectedColor = null;

    function selectColor(color) {
      selectedColor = color;

      // Update active swatch
      actions.querySelectorAll('.color-swatch').forEach(s => {
        s.classList.toggle('active', s.dataset.color === color.name);
      });

      // Update main image and thumbnails
      mainImg.src = color.images.front;
      if (thumbFront) thumbFront.src = color.images.front;
      if (thumbBack && color.images.back) thumbBack.src = color.images.back;

      // Repopulate size dropdown
      sizeSelect.innerHTML = '<option value="" selected disabled>—</option>';
      color.sizes.forEach(({ size }) => {
        const opt = document.createElement('option');
        opt.value = size;
        opt.textContent = size;
        sizeSelect.appendChild(opt);
      });
      sizeSelect.value = '';
      addBtn.disabled = true;
    }

    actions.querySelectorAll('.color-swatch').forEach(swatch => {
      swatch.addEventListener('click', () => {
        const color = colors.find(c => c.name === swatch.dataset.color);
        if (color) selectColor(color);
      });
    });

    sizeSelect.addEventListener('change', () => {
      addBtn.disabled = !selectedColor || !sizeSelect.value;
    });

    addBtn.addEventListener('click', () => {
      if (!selectedColor || !sizeSelect.value) return;
      Cart.add(
        actions.dataset.slug,
        actions.dataset.name,
        selectedColor.name,
        sizeSelect.value,
        parseFloat(actions.dataset.price),
        selectedColor.images.front
      );
    });

    // Select a random color on load (each card picks independently) so the grid
    // shows variety instead of an all-white row. This also populates sizes.
    const swatches = actions.querySelectorAll('.color-swatch');
    if (swatches.length) {
      swatches[Math.floor(Math.random() * swatches.length)].click();
    }
  });
</script>
