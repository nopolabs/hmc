---
title: Home
layout: layout.liquid
---

<div class="hero">
  <h1>HMC, <em>Cycling.</em></h1>
</div>

<div class="products">
  {% for product in products %}
    {% assign pmTable = product.size_guide.product_measure %}
    {% assign myTable = product.size_guide.measure_yourself %}

    <div class="product-card">
      <div class="product-image-wrapper">
        <img class="product-main-image" src="{{ product.images[0] }}" alt="{{ product.name }}">
      </div>
      {% if product.images.size > 1 %}
        <div class="product-thumbnails">
          {% for img in product.images %}
            <img src="{{ img }}" alt="{{ product.name }}" onclick="this.closest('.product-card').querySelector('.product-main-image').src = this.src">
          {% endfor %}
        </div>
      {% endif %}
      <div class="product-title-price">
        <h2>{{ product.name }}</h2>
        <p>${{ product.variants[0].price }}</p>
      </div>
      {% if product.description %}
        <p class="product-description">{{ product.description }}</p>
      {% endif %}
      {% if product.size_guide %}
        <button class="sg-trigger" data-size-guide="{{ product.slug }}" type="button">Size guide</button>
      {% endif %}
      <div class="product-actions"
           data-slug="{{ product.slug }}"
           data-name="{{ product.name }}"
           data-image="{{ product.images[0] }}">
        <div class="size-select-row">
          Size:
          <select class="size-select" required>
            <option value="" selected disabled>Select</option>
            {% for variant in product.variants %}
              <option value="{{ variant.size }}" data-price="{{ variant.price }}">{{ variant.size }}</option>
            {% endfor %}
          </select>
        </div>
        <button type="button" class="buy-button add-to-cart-btn">Add to Cart</button>
      </div>
    </div>

    {% if product.size_guide %}
    <div class="sg-overlay" id="sg-{{ product.slug }}" hidden>
      <div class="sg-modal" role="dialog" aria-modal="true" aria-labelledby="sg-title-{{ product.slug }}">
        <div class="sg-header">
          <h2 id="sg-title-{{ product.slug }}">Size guide</h2>
          <button class="sg-close" aria-label="Close">&#215;</button>
        </div>
        <div class="sg-tabs">
          {% if pmTable %}<button class="sg-tab active" data-tab="pm" type="button">Product measurements</button>{% endif %}
          {% if myTable %}<button class="sg-tab" data-tab="my" type="button">Measure yourself</button>{% endif %}
        </div>

        {% if pmTable %}
        <div class="sg-panel" data-panel="pm">
          <div class="sg-diagram">
            <img src="{{ pmTable.image_url }}" alt="Product measurement diagram">
            <div class="sg-diagram-desc">{{ pmTable.image_description }}</div>
          </div>
          <table class="sg-table">
            <thead>
              <tr>
                <th>Size</th>
                {% for m in pmTable.measurements %}<th>{{ m.type_label }}</th>{% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in pmTable.measurements[0].values %}
                {% assign rowIndex = forloop.index0 %}
                <tr>
                  <td>{{ row.size }}</td>
                  {% for m in pmTable.measurements %}
                    {% assign v = m.values[rowIndex] %}
                    <td>{% if v.value %}{{ v.value }}{% else %}{{ v.min_value }}–{{ v.max_value }}{% endif %}</td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
          <p class="sg-note">All measurements in inches. May vary by up to 2&#8243; (5&nbsp;cm).</p>
        </div>
        {% endif %}

        {% if myTable %}
        <div class="sg-panel" data-panel="my" hidden>
          <div class="sg-diagram">
            <img src="{{ myTable.image_url }}" alt="Measure yourself diagram">
            <div class="sg-diagram-desc">{{ myTable.image_description }}</div>
          </div>
          <table class="sg-table">
            <thead>
              <tr>
                <th>Size</th>
                {% for m in myTable.measurements %}<th>{{ m.type_label }}</th>{% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in myTable.measurements[0].values %}
                {% assign rowIndex = forloop.index0 %}
                <tr>
                  <td>{{ row.size }}</td>
                  {% for m in myTable.measurements %}
                    {% assign v = m.values[rowIndex] %}
                    <td>{% if v.value %}{{ v.value }}{% else %}{{ v.min_value }}–{{ v.max_value }}{% endif %}</td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
          <p class="sg-note">All measurements in inches. May vary by up to 2&#8243; (5&nbsp;cm).</p>
        </div>
        {% endif %}

      </div>
    </div>
    {% endif %}
  {% endfor %}
</div>

<script>
  document.querySelectorAll('[data-size-guide]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('sg-' + btn.dataset.sizeGuide).removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeSg(overlay) {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.sg-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => { if (e.target === overlay) closeSg(overlay); });
    overlay.querySelector('.sg-close').addEventListener('click', () => closeSg(overlay));
  });

  document.querySelectorAll('.sg-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const modal = tab.closest('.sg-modal');
      modal.querySelectorAll('.sg-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      modal.querySelectorAll('.sg-panel').forEach(p => p.hidden = true);
      modal.querySelector('[data-panel="' + tab.dataset.tab + '"]').hidden = false;
    });
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape')
      document.querySelectorAll('.sg-overlay:not([hidden])').forEach(closeSg);
  });

  document.querySelectorAll('.product-actions').forEach(actions => {
    const btn = actions.querySelector('.add-to-cart-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const select = actions.querySelector('.size-select');
      if (!select.value) {
        select.focus();
        select.reportValidity();
        return;
      }
      const opt = select.options[select.selectedIndex];
      Cart.add(
        actions.dataset.slug,
        actions.dataset.name,
        select.value,
        parseFloat(opt.dataset.price),
        actions.dataset.image
      );
    });
  });
</script>
